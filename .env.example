# LLM Provider Configuration
# Mode: 'mock' for offline testing without API key, or 'openai' / 'ollama' for live LLM
LLM_PROVIDER=mock
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=your_api_key_here
LLM_MODEL=gpt-4o-mini

# Optional Telegram Report Adapter
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Environment
NODE_ENV=development
